// schema.prisma
generator client {
  provider = "prisma-client-js"
  // output   = "./node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  driver
  admin
}

enum OrderStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
  RETURNED
}

model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  password     String
  phoneNumber  String?  @unique
  refreshToken String?  @unique
  role         Role     @default(customer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  customerOrders      Order[]               @relation("CustomerOrders")
  driverOrders        Order[]               @relation("DriverOrders")
  addresses           Address[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([phoneNumber])
}

model Address {
  id        String  @id @default(uuid())
  street    String?
  street2   String?
  city      String?
  state     String?
  zipCode   String?
  country   String?
  latitude  Float?
  longitude Float?
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  // Relations
  pickupOrders  Order[] @relation("OrderPickupAddress")
  dropoffOrders Order[] @relation("OrderDropoffAddress")
}

model Order {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
  version     Int     @default(1)
  // Customer relation
  customer    User    @relation("CustomerOrders", fields: [customerId], references: [id])
  customerId  String

  receiverFullName    String      @default("Full Name")
  receiverPhoneNumber Float       @default(0000000)
  // Driver relation
  driver              User?       @relation("DriverOrders", fields: [driverId], references: [id])
  driverId            String?
  // Address relations
  pickupAddress       Address     @relation("OrderPickupAddress", fields: [pickupAddressId], references: [id])
  pickupAddressId     String
  dropoffAddress      Address     @relation("OrderDropoffAddress", fields: [dropoffAddressId], references: [id])
  dropoffAddressId    String
  // Order details
  expectedVersion     Int?
  status              OrderStatus @default(PENDING)
  estimatedDistance   Float?
  estimatedDuration   Float?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  archived            Boolean     @default(false)

  @@index([customerId])
  @@index([driverId])
  @@index([status])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
